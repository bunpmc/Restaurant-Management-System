<Window x:Class="Restaurant_Management_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant_Management_System"
        mc:Ignorable="d"
        Title="Restaurant-Management-System-UI" Height="450" Width="800">
    <Grid Margin="0,0,0,-6" Background="#FFF6EEE3">
        <Grid>
            <Image HorizontalAlignment="Left" Height="124" Margin="10,10,0,0" VerticalAlignment="Top" Width="131" Source="/sushi-logo.png" RenderTransformOrigin="0.544,0.517"/>
            <Label Content="Dashboard" HorizontalAlignment="Left" Margin="182,50,0,0" VerticalAlignment="Top"/>
            <Label Content="Orders" HorizontalAlignment="Left" Margin="336,50,0,0" VerticalAlignment="Top"/>
            <Label Content="Menu" HorizontalAlignment="Left" Margin="477,50,0,0" VerticalAlignment="Top"/>
            <Label Content="Logout" HorizontalAlignment="Left" Margin="621,50,0,0" VerticalAlignment="Top"/>
            <StackPanel HorizontalAlignment="Left" Margin="136,145,0,0" Orientation="Vertical" VerticalAlignment="Top">
                <Label Content="Navigation Panel" Height="43" Width="159" FontSize="20"/>
                <Button Content="Orders" Height="38" Width="152" Panel.ZIndex="-3" Margin="0,7,0,0" BorderThickness="1,1,1,1"/>
                <Button Content="Menu Items" Width="152" Height="38" Panel.ZIndex="-3" Margin="0,7,0,0" Click="Button_Click"/>
                <Button Content="Tables" Width="152" Height="38" Panel.ZIndex="-3" Margin="0,7,0,0"/>
                <Button Content="Reports" Width="152" Height="38" Panel.ZIndex="-3" Margin="0,7,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Left" Margin="465,144,0,0" Orientation="Vertical" VerticalAlignment="Top">
                <Label Content="Quick Access" Height="43" Width="127" FontSize="20"/>
                <Button Content="Active Orders" Height="38" Width="152" Margin="0,6,0,0"/>
                <Button Content="Top-selling Dishes" Width="152" Height="38" Margin="0,6,0,0"/>
            </StackPanel>
            
        </Grid>

    </Grid>
</Window>
